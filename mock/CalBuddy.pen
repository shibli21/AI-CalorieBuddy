            },
            {
              "type": "text",
              "id": "xycNw",
              "name": "p155s1t",
              "fill": "$text-primary",
              "content": "1. Information We Collect",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "nRyq4",
              "name": "p155s1p",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "We collect information you provide directly to us, such as when you create an account, log meals, or contact us for support. This includes your name, email address, health data, and dietary preferences.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "4SMA0",
              "name": "p155s2t",
              "fill": "$text-primary",
              "content": "2. How We Use Your Information",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "Iy6JH",
              "name": "p155s2p",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "We use the information we collect to provide, maintain, and improve our services, including personalized nutrition recommendations, calorie tracking, and AI-powered meal analysis.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "hAAQz",
              "name": "p155s3t",
              "fill": "$text-primary",
              "content": "3. Data Security",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "jzNUU",
              "name": "p155s3p",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "We take reasonable measures to help protect your personal information from loss, theft, misuse, and unauthorized access. All data is encrypted in transit and at rest.",
              "lineHeight": 1.6,
              "fontFamily": "Inter",
              "fontSize": 14,
              "fontWeight": "normal"
            }
          ]
        }
      ]
    },
